generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Departamentos ────────────────────────────────────────────────────────────

model Departamento {
  id           String   @id @default(cuid())
  nome         String
  descricao    String?
  cor          String   @default("#3b82f6")
  ativo        Boolean  @default(true)
  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  membros     MembroDepartamento[]
  chamados    Chamado[]
  colunas     ColunaKanban[]
  categorias  Categoria[]
  prioridades Prioridade[]
  horarios    HorarioAtendimento[]
  autoRegras  AutoRegra[]
}

model MembroDepartamento {
  id             String   @id @default(cuid())
  usuarioId      String
  departamentoId String
  adicionadoEm   DateTime @default(now())

  usuario      Usuario      @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  departamento Departamento @relation(fields: [departamentoId], references: [id], onDelete: Cascade)

  @@unique([usuarioId, departamentoId])
}

// ─── Configuração de E-mail ───────────────────────────────────────────────────

model ConfiguracaoEmail {
  id           String   @id @default(cuid())
  caixaEmail   String
  accessToken  String   @db.Text
  refreshToken String   @db.Text
  expiresAt    DateTime
  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt
}

// ─── Autenticação (NextAuth) ───────────────────────────────────────────────────

model Usuario {
  id           String        @id @default(cuid())
  nome         String
  email        String        @unique
  cargo        Cargo         @default(HC)
  status       StatusUsuario @default(PENDENTE)
  microsoftId  String?       @unique
  imagem       String?
  criadoEm     DateTime      @default(now())
  atualizadoEm DateTime      @updatedAt

  contas                   Conta[]
  sessoes                  Sessao[]
  chamadosResponsavel      Chamado[]             @relation("ResponsavelChamado")
  assinaturas              AssinaturaEmail[]
  participantesAdicionados ParticipanteChamado[] @relation("AdicionadoPor")
  departamentos            MembroDepartamento[]
}

model Conta {
  id                String  @id @default(cuid())
  usuarioId         String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  usuario Usuario @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Sessao {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  usuarioId    String
  expires      DateTime

  usuario Usuario @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
}

model TokenVerificacao {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Clientes ─────────────────────────────────────────────────────────────────

model Cliente {
  id           String   @id @default(cuid())
  email        String   @unique
  nome         String?
  empresa      String?
  cnpj         String?
  telefone     String?
  rede         String?
  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  participacoes ParticipanteChamado[]
}

// ─── E-mail ────────────────────────────────────────────────────────────────────

model AssinaturaEmail {
  id           String   @id @default(cuid())
  usuarioId    String
  nome         String
  conteudoHtml String   @db.Text
  padrao       Boolean  @default(false)
  criadoEm     DateTime @default(now())

  usuario Usuario @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
}

model TemplateEmail {
  id           String   @id @default(cuid())
  nome         String
  assunto      String
  conteudoHtml String   @db.Text
  criadoPorId  String
  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt
}

// ─── Configurações do Kanban ───────────────────────────────────────────────────

model ColunaKanban {
  id             String   @id @default(cuid())
  nome           String
  ordem          Int
  cor            String   @default("#6366f1")
  padrao         Boolean  @default(false)
  resolvido      Boolean  @default(false)
  criadoEm       DateTime @default(now())
  departamentoId String?

  chamados     Chamado[]
  departamento Departamento? @relation(fields: [departamentoId], references: [id])
}

// ─── Categorias e Prioridades ─────────────────────────────────────────────────

model Categoria {
  id             String   @id @default(cuid())
  nome           String
  descricao      String?
  criadoEm       DateTime @default(now())
  departamentoId String?

  atribuicoes  AtribuicaoCategoria[]
  chamados     Chamado[]
  regras       RegraCategoria[]
  departamento Departamento? @relation(fields: [departamentoId], references: [id])
}

model HorarioAtendimento {
  id             String  @id @default(cuid())
  diaSemana      Int     // 0=Dom, 1=Seg, ..., 6=Sab
  horaInicio     String  @default("08:00")
  horaFim        String  @default("18:00")
  ativo          Boolean @default(false)
  departamentoId String?

  departamento Departamento? @relation(fields: [departamentoId], references: [id])
}

// ─── Regras Automáticas ───────────────────────────────────────────────────────

model AutoRegra {
  id             String   @id @default(cuid())
  nome           String
  descricao      String?
  ativo          Boolean  @default(true)
  ordem          Int      @default(0)
  gatilho        String   // "CHAMADO_CRIADO" | "CHAMADO_RESOLVIDO"
  operador       String   @default("E") // "E" (AND) | "OU" (OR)
  departamentoId String?
  criadoEm       DateTime @default(now())
  atualizadoEm   DateTime @updatedAt

  condicoes    CondicaoAutoRegra[]
  acoes        AcaoAutoRegra[]
  departamento Departamento? @relation(fields: [departamentoId], references: [id], onDelete: SetNull)

  @@index([departamentoId, gatilho, ativo])
}

model CondicaoAutoRegra {
  id       String @id @default(cuid())
  regraId  String
  campo    String // "assunto"|"deEmail"|"dominio"|"conteudo"|"categoriaId"|"prioridadeId"
  operador String // "contem"|"nao_contem"|"igual"|"diferente"|"comeca_com"|"termina_com"
  valor    String

  regra AutoRegra @relation(fields: [regraId], references: [id], onDelete: Cascade)
}

model AcaoAutoRegra {
  id      String @id @default(cuid())
  regraId String
  tipo    String // "DEFINIR_CATEGORIA"|"DEFINIR_PRIORIDADE"|"DEFINIR_COLUNA"|"ATRIBUIR_USUARIO"|"ENVIAR_EMAIL"|"NOTIFICAR_INTERNO"
  valor   String // ID da entidade, "responsavel"/"admins" ou "user:{id}"

  regra AutoRegra @relation(fields: [regraId], references: [id], onDelete: Cascade)
}

// ─── Regras Simples (legado) ──────────────────────────────────────────────────

model RegraCategoria {
  id           String   @id @default(cuid())
  palavraChave String
  categoriaId  String
  criadoEm     DateTime @default(now())

  categoria Categoria @relation(fields: [categoriaId], references: [id], onDelete: Cascade)
}

model AtribuicaoCategoria {
  id          String  @id @default(cuid())
  categoriaId String
  usuarioId   String?

  categoria Categoria @relation(fields: [categoriaId], references: [id], onDelete: Cascade)

  @@unique([categoriaId, usuarioId])
}

model Prioridade {
  id             String   @id @default(cuid())
  nome           String
  horasSla       Int      @default(8)
  cor            String   @default("#f59e0b")
  ordem          Int      @default(0)
  criadoEm       DateTime @default(now())
  departamentoId String?

  chamados     Chamado[]
  departamento Departamento? @relation(fields: [departamentoId], references: [id])
}

// ─── Chamados ─────────────────────────────────────────────────────────────────

model Chamado {
  id               String        @id @default(cuid())
  assunto          String
  responsavelId    String?
  colunaId         String
  colunaAnteriorId String?
  prioridadeId     String?
  categoriaId      String?
  departamentoId   String?
  threadId         String?       @unique
  prazoSla         DateTime?
  slaPausadoEm     DateTime?
  resolvidoEm      DateTime?
  origem           OrigemChamado @default(RECEBIDO)
  criadoEm         DateTime      @default(now())
  atualizadoEm     DateTime      @updatedAt

  responsavel  Usuario?     @relation("ResponsavelChamado", fields: [responsavelId], references: [id])
  coluna       ColunaKanban @relation(fields: [colunaId], references: [id])
  prioridade   Prioridade?  @relation(fields: [prioridadeId], references: [id])
  categoria    Categoria?   @relation(fields: [categoriaId], references: [id])
  departamento Departamento? @relation(fields: [departamentoId], references: [id])
  participantes ParticipanteChamado[]
  mensagens    MensagemEmail[]
}

model ParticipanteChamado {
  id              String           @id @default(cuid())
  chamadoId       String
  clienteId       String
  tipo            TipoDestinatario
  adicionadoEm    DateTime         @default(now())
  adicionadoPorId String?
  removidoEm      DateTime?

  chamado       Chamado  @relation(fields: [chamadoId], references: [id], onDelete: Cascade)
  cliente       Cliente  @relation(fields: [clienteId], references: [id])
  adicionadoPor Usuario? @relation("AdicionadoPor", fields: [adicionadoPorId], references: [id])

  @@unique([chamadoId, clienteId, tipo])
}

// ─── Mensagens ────────────────────────────────────────────────────────────────

model MensagemEmail {
  id              String          @id @default(cuid())
  chamadoId       String
  deEmail         String
  deNome          String?
  conteudoHtml    String          @db.Text
  direcao         DirecaoMensagem
  encaminhamento  Boolean         @default(false)
  graphMensagemId String?         @unique
  messageId       String?         @unique
  enviadoEm       DateTime        @default(now())

  chamado       Chamado                @relation(fields: [chamadoId], references: [id], onDelete: Cascade)
  destinatarios DestinatarioMensagem[]
  anexos        AnexoMensagem[]
}

model DestinatarioMensagem {
  id         String           @id @default(cuid())
  mensagemId String
  email      String
  nome       String?
  tipo       TipoDestinatario

  mensagem MensagemEmail @relation(fields: [mensagemId], references: [id], onDelete: Cascade)
}

model AnexoMensagem {
  id               String   @id @default(cuid())
  mensagemId       String
  nomeArquivo      String
  tamanho          Int
  mimeType         String
  urlArmazenamento String
  criadoEm         DateTime @default(now())

  mensagem MensagemEmail @relation(fields: [mensagemId], references: [id], onDelete: Cascade)
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum Cargo {
  ADM
  HC
}

enum StatusUsuario {
  PENDENTE
  ATIVO
  INATIVO
}

enum OrigemChamado {
  RECEBIDO
  INICIADO
}

enum DirecaoMensagem {
  ENTRADA
  SAIDA
}

enum TipoDestinatario {
  PARA
  CC
  CCO
}
